# Force LF line endings in the repo for all text files.
# Windows users get CRLF in their working dir, but the repo stays LF.
* text=auto eol=lf

# Explicit text files
*.py     text eol=lf
*.md     text eol=lf
*.json   text eol=lf
*.toml   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.txt    text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
LICENSE  text eol=lf

# Windows-only files keep CRLF
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# Binary files: never touch line endings
*.zip    binary
*.parquet binary
*.png    binary
*.jpg    binary
*.pdf    binary
*.dta    binary
*.sav    binary