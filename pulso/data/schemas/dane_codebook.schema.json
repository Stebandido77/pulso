{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pulso-co.dev/schemas/dane_codebook-1.0.0.json",
  "title": "DANE GEIH codebook",
  "description": "Auto-generated catalogue of every variable DANE publishes in its DDI-XML metadata for the GEIH microdata. Keyed by raw DANE code (P-codes, FEX_C18, OCI, etc.). Complementary to variable_map.json (which maps canonical Spanish names to DANE codes per epoch).",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "source",
    "coverage_years",
    "epochs",
    "variables"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "generated_at": {
      "type": "string",
      "description": "ISO-8601 timestamp (UTC) of the build run."
    },
    "source": {
      "type": "string",
      "description": "Free-text description of the upstream source (e.g. 'DANE DDI-XML 1.2.2')."
    },
    "coverage_years": {
      "type": "array",
      "items": {"type": "integer", "minimum": 2000, "maximum": 2100},
      "uniqueItems": true,
      "minItems": 1
    },
    "epochs": {
      "type": "object",
      "description": "Per-epoch summary derived from the parsed years. Keys must match pulso/data/epochs.json.",
      "additionalProperties": {
        "type": "object",
        "required": ["years", "variable_count"],
        "additionalProperties": false,
        "properties": {
          "years": {
            "type": "array",
            "items": {"type": "integer", "minimum": 2000, "maximum": 2100},
            "uniqueItems": true
          },
          "variable_count": {"type": "integer", "minimum": 0}
        }
      }
    },
    "variables": {
      "type": "object",
      "description": "Map keyed by DANE variable code (e.g. P3271, FEX_C18, OCI).",
      "additionalProperties": {"$ref": "#/definitions/variable"}
    }
  },
  "definitions": {
    "variable": {
      "type": "object",
      "required": ["code", "label", "type", "available_in"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "description": "DANE variable code; must equal the parent dict key."
        },
        "label": {
          "type": "string",
          "description": "Human-readable label (from <labl>) of the most recent year."
        },
        "type": {
          "type": "string",
          "enum": ["categorical", "numeric", "character", "unknown"]
        },
        "question_text": {
          "type": ["string", "null"],
          "description": "Question literal (<qstn><qstnLit>) for the most recent year."
        },
        "universe": {
          "type": ["string", "null"],
          "description": "Universe (<universe>) for the most recent year."
        },
        "response_unit": {
          "type": ["string", "null"],
          "description": "Response unit (<respUnit>) for the most recent year."
        },
        "categories": {
          "type": ["object", "null"],
          "description": "{catValu: labl} for the most recent year, when categorical.",
          "additionalProperties": {"type": "string"}
        },
        "value_range": {
          "anyOf": [
            {"type": "null"},
            {
              "type": "object",
              "required": ["min", "max"],
              "additionalProperties": false,
              "properties": {
                "min": {"type": "number"},
                "max": {"type": "number"}
              }
            }
          ]
        },
        "notes": {
          "type": ["string", "null"],
          "description": "Concatenated <txt> contents (free-form glossary)."
        },
        "available_in": {
          "type": "object",
          "description": "One entry per year where the code appears. Keys are 4-digit year strings.",
          "additionalProperties": {"$ref": "#/definitions/year_entry"},
          "minProperties": 1
        }
      }
    },
    "year_entry": {
      "type": "object",
      "required": ["epoch"],
      "additionalProperties": false,
      "properties": {
        "epoch": {
          "type": "string",
          "description": "Epoch key matching pulso/data/epochs.json."
        },
        "file_id_in_year": {
          "type": ["string", "null"],
          "description": "DDI <var files=...> attribute (informational; not stable across years)."
        },
        "var_id_in_year": {
          "type": ["string", "null"],
          "description": "DDI <var ID=...> attribute (informational; not stable across years)."
        },
        "label": {"type": ["string", "null"]},
        "type": {
          "type": "string",
          "enum": ["categorical", "numeric", "character", "unknown"]
        },
        "question_text": {"type": ["string", "null"]},
        "categories": {
          "type": ["object", "null"],
          "additionalProperties": {"type": "string"}
        },
        "value_range": {
          "anyOf": [
            {"type": "null"},
            {
              "type": "object",
              "required": ["min", "max"],
              "additionalProperties": false,
              "properties": {
                "min": {"type": "number"},
                "max": {"type": "number"}
              }
            }
          ]
        }
      }
    }
  }
}
